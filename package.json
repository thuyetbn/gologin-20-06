{
  "name": "gologin-manager",
  "displayName": "GoLogin Manager - ThuyetBN",
  "version": "1.0.0",
  "description": "GoLogin Manager - ThuyetBN",
  "private": false,
  "license": "MIT",
  "main": "dist/backend/index.js",
  "author": {
    "name": "ThuyetBN",
    "email": "thuyetbn@gmail.com",
    "url": "https://github.com/thuyetbn"
  },
  "scripts": {
    "dev": "yarn build:backend && electron . --dev",
    "prebuild": "rimraf out && rimraf dist",
    "build:frontend": "next build src",
    "build:backend": "tsc -p backend && node scripts/copy-assets.js",
    "build": "yarn build:frontend && yarn build:backend",
    "build:safe": "yarn build:frontend && yarn build:backend",
    "postinstall": "electron-builder install-app-deps",
    "dist": "yarn build && electron-builder",
    "dist:safe": "yarn build:safe && electron-builder",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:mac:universal": "yarn build && electron-builder --mac --universal",
    "dist:mac:x64": "yarn build && electron-builder --mac --x64",
    "dist:mac:arm64": "yarn build && electron-builder --mac --arm64",
    "dist:win": "yarn build && electron-builder --win",
    "dist:linux": "yarn build && electron-builder --linux",
    "clean": "rimraf out && rimraf dist && rimraf node_modules/.cache",
    "electron-rebuild": "electron-rebuild",
    "update:readme": "tsx scripts/update-readme.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@reactflow/background": "^11.3.14",
    "@reactflow/controls": "^11.2.14",
    "@reactflow/core": "^11.11.4",
    "@reactflow/minimap": "^11.7.14",
    "@reactflow/node-resizer": "^2.2.14",
    "@reactflow/node-toolbar": "^1.3.14",
    "@sentry/node": "^9.30.0",
    "@types/dagre": "^0.7.53",
    "adm-zip": "^0.5.16",
    "app-root-path": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "decompress": "^4.2.1",
    "electron-log": "^5.4.0",
    "electron-store": "^10.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.518.0",
    "playwright-core": "^1.54.1",
    "puppeteer-core": "^24.10.2",
    "react-hook-form": "^7.61.1",
    "reactflow": "^11.11.4",
    "request": "^2.88.2",
    "requestretry": "^7.1.0",
    "rimraf": "3",
    "sc-prepare-next": "^1.0.3",
    "sequelize": "^6.37.7",
    "sonner": "^2.0.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.0.5",
    "uuid": "^11.1.0",
    "yup": "^1.6.1",
    "portfinder": "^1.0.32",
    "is-port-reachable": "^4.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.18",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "fs-extra": "^11.3.0",
    "next": "15.3.3",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.thuyetbn.gologinmanager",
    "productName": "GoLogin Manager",
    "files": [
      "dist/**/*",
      "out/**/*",
      "!dist/**/*.ts",
      "!dist/tsconfig.json",
      "!out/**/*.map"
    ],
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${name}-${version}-windows-${arch}.${ext}",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${name}-${version}-linux-${arch}.${ext}",
      "icon": "assets/icon.png"
    },
    "publish": null
  }
}
