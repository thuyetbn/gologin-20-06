{
  "name": "sc-next-electron",
  "displayName": "SC - Electron and Next",
  "version": "11.0.1",
  "description": "SC - Electron and Next",
  "private": false,
  "license": "MIT",
  "main": "dist/backend/index.js",
  "author": {
    "name": "Saulo Costa",
    "email": "saulotarsobc@gmail.com",
    "url": "https://github.com/saulotarsobc"
  },
  "scripts": {
    "dev": "yarn build:backend && electron . --dev",
    "prebuild": "rimraf out && rimraf dist",
    "build:frontend": "next build src",
    "build:backend": "tsc -p backend && node scripts/copy-assets.js",
    "build": "yarn build:frontend && yarn build:backend",
    "postinstall": "electron-builder install-app-deps",
    "dist": "yarn build && electron-builder",
    "update:readme": "tsx scripts/update-readme.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@sentry/node": "^9.30.0",
    "adm-zip": "^0.5.16",
    "app-root-path": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decompress": "^4.2.1",
    "electron-log": "^5.4.0",
    "electron-store": "^10.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.518.0",
    "puppeteer-core": "^24.10.2",
    "request": "^2.88.2",
    "requestretry": "^7.1.0",
    "rimraf": "3",
    "sc-prepare-next": "^1.0.3",
    "sequelize": "^6.37.7",
    "sonner": "^2.0.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.0.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.18",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "fs-extra": "^11.3.0",
    "next": "15.3.3",
    "postcss": "^8.5.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "br.com.electron.next",
    "productName": "SC - Electron and Next",
    "files": [
      "dist"
    ],
    "directories": {
      "output": "out"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${name}-${version}-windows-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "signIgnore": null,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${name}-${version}-linux-${arch}.${ext}"
    }
  }
}
