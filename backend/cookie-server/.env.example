# Cookie Server Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: 'mysql' or 'sqlite'
DB_TYPE=mysql

# MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=cookie_user
DB_PASSWORD=your_strong_password_here
DB_NAME=cookie_server

# MySQL Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=60000
DB_TIMEOUT=60000
DB_IDLE_TIMEOUT=300000

# MySQL SSL Configuration (optional)
# DB_SSL=true
# DB_SSL_CA=/path/to/ca.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# SQLite Configuration (fallback)
COOKIE_DB_PATH=./data/cookies.db
COOKIE_DB_BACKUP_PATH=./data/backups
DB_MAX_CONNECTIONS=10
DB_BUSY_TIMEOUT=30000

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server Settings
COOKIE_SERVER_PORT=3001
COOKIE_SERVER_HOST=localhost
NODE_ENV=development

# Base URL for the server
BASE_URL=http://localhost:3001

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here_32_characters_minimum

# API Key Secret (generate with: openssl rand -hex 32)
API_KEY_SECRET=your_api_key_secret_here_32_characters_minimum

# Encryption Key for sensitive data (must be 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Session Secret
SESSION_SECRET=your_session_secret_here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# CORS Credentials
CORS_CREDENTIALS=true

# =============================================================================
# RATE LIMITING
# =============================================================================

# Rate limit window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# Rate limit for API endpoints
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=30

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log Level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# Log File Path
LOG_FILE_PATH=./logs/cookie-server.log

# Error Log Path
ERROR_LOG_PATH=./logs/error.log

# Access Log Path
ACCESS_LOG_PATH=./logs/access.log

# Log Rotation
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# Console Logging
LOG_CONSOLE=true

# =============================================================================
# GOLOGIN INTEGRATION
# =============================================================================

# GoLogin API Configuration
GOLOGIN_API_URL=https://api.gologin.com
GOLOGIN_API_TIMEOUT=30000

# Default GoLogin Settings
DEFAULT_GOLOGIN_TIMEOUT=30000
DEFAULT_GOLOGIN_RETRIES=3

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup Directory
BACKUP_DIR=./backups

# Automatic Backup Settings
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL=24h
AUTO_BACKUP_RETENTION=30d

# Backup Compression
BACKUP_COMPRESSION=gzip

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# Redis Configuration (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# =============================================================================
# MONITORING & HEALTH CHECKS
# =============================================================================

# Health Check Settings
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Metrics Collection
METRICS_ENABLED=true
METRICS_PORT=9090

# Performance Monitoring
PERFORMANCE_MONITORING=true

# =============================================================================
# EMAIL CONFIGURATION (for notifications)
# =============================================================================

# SMTP Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Email Notifications
# EMAIL_NOTIFICATIONS=true
# ADMIN_EMAIL=admin@yourdomain.com

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================

# Webhook Settings
# WEBHOOK_ENABLED=false
# WEBHOOK_URL=https://your-webhook-endpoint.com/webhook
# WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Debug Mode
DEBUG=false

# Development Features
DEV_MODE=false
DEV_CORS_ORIGIN=*

# Hot Reload
HOT_RELOAD=true

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_PATH=/api/docs

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Production Optimizations
PRODUCTION_OPTIMIZATIONS=true

# Cluster Mode
CLUSTER_MODE=false
CLUSTER_WORKERS=auto

# Process Management
PM2_ENABLED=false
PM2_INSTANCES=max

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature Toggles
FEATURE_BROWSER_HISTORY=true
FEATURE_SAVED_PASSWORDS=true
FEATURE_BOOKMARKS=true
FEATURE_FULL_BACKUP=true
FEATURE_AUTO_SYNC=true
FEATURE_ENCRYPTION=true

# Experimental Features
EXPERIMENTAL_FEATURES=false
EXPERIMENTAL_COMPRESSION=false
EXPERIMENTAL_STREAMING=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Analytics
# ANALYTICS_ENABLED=false
# ANALYTICS_PROVIDER=google
# ANALYTICS_ID=GA-XXXXXXXXX

# Error Tracking
# ERROR_TRACKING_ENABLED=false
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# CUSTOM SETTINGS
# =============================================================================

# Custom Application Settings
APP_NAME=Cookie Server
APP_VERSION=1.0.0
APP_DESCRIPTION=Custom Cookie Storage and Synchronization Server

# Custom Timeouts
CUSTOM_REQUEST_TIMEOUT=30000
CUSTOM_UPLOAD_TIMEOUT=60000
CUSTOM_DOWNLOAD_TIMEOUT=60000

# Custom Limits
MAX_COOKIES_PER_PROFILE=50000
MAX_HISTORY_ITEMS_PER_PROFILE=100000
MAX_PASSWORDS_PER_PROFILE=10000
MAX_BOOKMARKS_PER_PROFILE=20000

# Custom Features
CUSTOM_VALIDATION=true
CUSTOM_SANITIZATION=true
CUSTOM_COMPRESSION=true
